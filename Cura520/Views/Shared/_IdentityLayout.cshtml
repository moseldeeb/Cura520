                        @if (!User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item"><a class="nav-link" href="/Identity/Account/Login">Login</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Identity/Account/Register">Register</a></li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" href="/Identity/Account/Logout">Logout</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Identity/Profile/Index">Welcome @User.Identity.Name </a></li>
                        }
                    </ul>
                </div>
            </div>
