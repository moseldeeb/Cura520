@model Cura520.ViewModel.ValidateOTPVM

@{
    ViewData["Title"] = "Verify OTP";
    
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg">
                <div class="card-header bg-info text-white">
                    <h3 class="mb-0">
                        <i class="fas fa-shield-alt me-2"></i>Verify OTP
                    </h3>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted mb-4">
                        Enter the OTP sent to your email address to proceed.
                    </p>

                    <form asp-action="ValidateOTP" asp-controller="Account" asp-area="Identity" method="post">
                        <div asp-validation-summary="All" class="alert alert-danger alert-dismissible fade show" role="alert">
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            <h6 class="alert-heading">Please fix the following errors:</h6>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="OTP" class="form-label fw-bold">
                                <i class="fas fa-key me-2"></i>Enter OTP
                            </label>
                            <input asp-for="OTP" class="form-control form-control-lg text-center" 
                                   placeholder="000000" 
                                   maxlength="6"
                                   inputmode="numeric"
                                   style="font-size: 1.5rem; letter-spacing: 0.5rem;" />
                            <span asp-validation-for="OTP" class="invalid-feedback d-block"></span>
                            <small class="text-muted d-block mt-2">Enter the 6-digit OTP</small>
                        </div>

                        <!-- Hidden input for ApplicationUserId -->
                        <input asp-for="ApplicationUserId" class="d-none" />

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-info btn-lg fw-bold text-white">
                                <i class="fas fa-check me-2"></i>Verify OTP
                            </button>
                        </div>
                    </form>

                    <hr class="my-4" />

                    <div class="alert alert-warning">
                        <h6 class="alert-heading">
                            <i class="fas fa-info-circle me-2"></i>Important
                        </h6>
                        <ul class="mb-0 small">
                            <li>OTP is valid for 10 minutes only</li>
                            <li>Check your email's spam folder if you didn't receive it</li>
                            <li>Each OTP can only be used once</li>
                        </ul>
                    </div>

                    <div class="text-center">
                        <p class="mb-0 small text-muted">
                            Didn't receive OTP?
                            <a asp-action="ForgetPassword" asp-controller="Account" asp-area="Identity" 
                               class="btn btn-link btn-sm p-0">
                                Request New OTP
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Auto-format OTP input to only allow numbers
        document.querySelector('input[asp-for="OTP"]')?.addEventListener('input', function(e) {
            this.value = this.value.replace(/[^0-9]/g, '');
            if (this.value.length > 6) {
                this.value = this.value.slice(0, 6);
            }
        });
    </script>
}
