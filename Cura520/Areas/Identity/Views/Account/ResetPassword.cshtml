@model Cura520.ViewModel.ResetPasswordVM

@{
    ViewData["Title"] = "Reset Password";
    
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg">
                <div class="card-header bg-warning text-dark">
                    <h3 class="mb-0">
                        <i class="fas fa-key me-2"></i>Reset Password
                    </h3>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted mb-4">
                        Create a new strong password for your account.
                    </p>

                    <form asp-action="ResetPassword" asp-controller="Account" asp-area="Identity" method="post">
                        <div asp-validation-summary="All" class="alert alert-danger alert-dismissible fade show" role="alert">
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            <h6 class="alert-heading">Please fix the following errors:</h6>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="NewPassword" class="form-label fw-bold">
                                <i class="fas fa-lock me-2"></i>New Password
                            </label>
                            <input asp-for="NewPassword" class="form-control form-control-lg" 
                                   placeholder="Enter a new password" 
                                   type="password"
                                   autocomplete="new-password" />
                            <span asp-validation-for="NewPassword" class="invalid-feedback d-block"></span>
                            <small class="text-muted d-block mt-1">At least 6 characters</small>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="ConfirmNewPassword" class="form-label fw-bold">
                                <i class="fas fa-lock me-2"></i>Confirm New Password
                            </label>
                            <input asp-for="ConfirmNewPassword" class="form-control form-control-lg" 
                                   placeholder="Confirm your new password" 
                                   type="password"
                                   autocomplete="new-password" />
                            <span asp-validation-for="ConfirmNewPassword" class="invalid-feedback d-block"></span>
                        </div>

                        <!-- Hidden input for ApplicationUserId -->
                        <input asp-for="ApplicationUserId" class="d-none" />

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning btn-lg fw-bold">
                                <i class="fas fa-save me-2"></i>Reset Password
                            </button>
                        </div>
                    </form>

                    <hr class="my-4" />

                    <div class="alert alert-success">
                        <h6 class="alert-heading">
                            <i class="fas fa-shield-alt me-2"></i>Password Tips
                        </h6>
                        <ul class="mb-0 small">
                            <li>Use a mix of uppercase and lowercase letters</li>
                            <li>Include numbers and special characters</li>
                            <li>Make it at least 8 characters long</li>
                            <li>Don't use personal information</li>
                        </ul>
                    </div>

                    <div class="text-center">
                        <p class="mb-0 small text-muted">
                            Remember your password now?
                            <a asp-action="Login" asp-controller="Account" asp-area="Identity" 
                               class="btn btn-link btn-sm p-0">
                                Go to Login
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
