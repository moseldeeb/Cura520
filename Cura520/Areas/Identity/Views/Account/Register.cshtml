@using Cura520.ViewModel.Identity
@model RegisterVM

@{
    ViewData["Title"] = "Register";
    
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-lg">
                <div class="card-header bg-success text-white">
                    <h3 class="mb-0">
                        <i class="fas fa-user-plus me-2"></i>Create Account
                    </h3>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted mb-4">
                        Join Cura 520 and manage your health appointments online.
                    </p>

                    <form asp-action="Register" asp-controller="Account" asp-area="Identity" method="post">
                        <div asp-validation-summary="All" class="alert alert-danger alert-dismissible fade show" role="alert">
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            <h6 class="alert-heading">Please fix the following errors:</h6>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="FirstName" class="form-label fw-bold">
                                    <i class="fas fa-user me-2"></i>First Name
                                </label>
                                <input asp-for="FirstName" class="form-control form-control-lg" 
                                       placeholder="John" />
                                <span asp-validation-for="FirstName" class="invalid-feedback d-block"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="LastName" class="form-label fw-bold">
                                    <i class="fas fa-user me-2"></i>Last Name
                                </label>
                                <input asp-for="LastName" class="form-control form-control-lg" 
                                       placeholder="Doe" />
                                <span asp-validation-for="LastName" class="invalid-feedback d-block"></span>
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="UserName" class="form-label fw-bold">
                                <i class="fas fa-at me-2"></i>Username
                            </label>
                            <input asp-for="UserName" class="form-control form-control-lg" 
                                   placeholder="johndoe123" />
                            <span asp-validation-for="UserName" class="invalid-feedback d-block"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Email" class="form-label fw-bold">
                                <i class="fas fa-envelope me-2"></i>Email Address
                            </label>
                            <input asp-for="Email" class="form-control form-control-lg" 
                                   placeholder="john@example.com" 
                                   type="email"
                                   autocomplete="email" />
                            <span asp-validation-for="Email" class="invalid-feedback d-block"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Password" class="form-label fw-bold">
                                <i class="fas fa-lock me-2"></i>Password
                            </label>
                            <input asp-for="Password" class="form-control form-control-lg" 
                                   placeholder="Enter a strong password" 
                                   autocomplete="new-password" />
                            <span asp-validation-for="Password" class="invalid-feedback d-block"></span>
                            <small class="text-muted d-block mt-1">At least 6 characters</small>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="ConfirmPassword" class="form-label fw-bold">
                                <i class="fas fa-lock me-2"></i>Confirm Password
                            </label>
                            <input asp-for="ConfirmPassword" class="form-control form-control-lg" 
                                   placeholder="Confirm your password" 
                                   autocomplete="new-password" />
                            <span asp-validation-for="ConfirmPassword" class="invalid-feedback d-block"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg fw-bold">
                                <i class="fas fa-user-plus me-2"></i>Create Account
                            </button>
                        </div>
                    </form>

                    <hr class="my-4" />

                    <div class="text-center">
                        <p class="mb-0">Already have an account?</p>
                        <a asp-action="Login" asp-controller="Account" asp-area="Identity" 
                           class="btn btn-link fw-bold text-decoration-none">
                            <i class="fas fa-sign-in-alt me-1"></i>Login Here
                        </a>
                    </div>
                </div>
            </div>

            <div class="alert alert-info mt-3">
                <h6 class="alert-heading">
                    <i class="fas fa-shield-alt me-2"></i>Security & Privacy
                </h6>
                <ul class="mb-0 small">
                    <li>Your password will be encrypted and stored securely</li>
                    <li>We require email confirmation to activate your account</li>
                    <li>You'll receive a confirmation link via email</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
