@model Cura520.ViewModel.LoginVm

@{
    ViewData["Title"] = "Login";
   
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">
                        <i class="fas fa-sign-in-alt me-2"></i>Login
                    </h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Login" asp-controller="Account" asp-area="Identity" method="post">
                        <div asp-validation-summary="All" class="alert alert-danger alert-dismissible fade show" role="alert">
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            <h6 class="alert-heading">Please fix the following errors:</h6>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="UserNameOrEmail" class="form-label fw-bold">
                                <i class="fas fa-user me-2"></i>Username or Email
                            </label>
                            <input asp-for="UserNameOrEmail" class="form-control form-control-lg" 
                                   placeholder="Enter your username or email" 
                                   autocomplete="username" />
                            <span asp-validation-for="UserNameOrEmail" class="invalid-feedback d-block"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Password" class="form-label fw-bold">
                                <i class="fas fa-lock me-2"></i>Password
                            </label>
                            <input asp-for="Password" class="form-control form-control-lg" 
                                   placeholder="Enter your password" 
                                   autocomplete="current-password" />
                            <span asp-validation-for="Password" class="invalid-feedback d-block"></span>
                        </div>

                        <div class="form-group form-check mb-3">
                            <input asp-for="RememberMe" class="form-check-input" id="RememberMe" />
                            <label class="form-check-label" for="RememberMe">
                                <i class="fas fa-check-circle me-1"></i>Remember me
                            </label>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold">
                                <i class="fas fa-sign-in-alt me-2"></i>Login
                            </button>
                        </div>
                    </form>

                    <hr class="my-4" />

                    <div class="text-center">
                        <p class="mb-3">
                            <a asp-action="ForgetPassword" asp-controller="Account" asp-area="Identity" 
                               class="btn btn-link text-decoration-none">
                                <i class="fas fa-key me-1"></i>Forgot Password?
                            </a>
                        </p>
                    </div>

                    <div class="text-center">
                        <p class="mb-3">
                            <a asp-action="ResendEmailConfirmation" asp-controller="Account" asp-area="Identity" 
                               class="btn btn-link text-decoration-none">
                                <i class="fas fa-envelope me-1"></i>Resend Email Confirmation
                            </a>
                        </p>
                    </div>

                    <div class="text-center">
                        <p class="mb-0">Don't have an account?</p>
                        <a asp-action="Register" asp-controller="Account" asp-area="Identity" 
                           class="btn btn-link fw-bold text-decoration-none">
                            <i class="fas fa-user-plus me-1"></i>Create Account
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <partial name="_NotificationPartial" />
}
