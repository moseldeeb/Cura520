@model Cura520.Models.Doctor

@{
    ViewData["Title"] = "Doctor Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Doctor Profile</h1>
        <div>
            <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-sm btn-info shadow-sm">
                <i class="fas fa-edit fa-sm text-white-50"></i> Edit Profile
            </a>
            <a asp-action="Home" class="btn btn-sm btn-secondary shadow-sm">
                <i class="fas fa-arrow-left fa-sm text-white-50"></i> Back to List
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-xl-4 col-lg-5">
            <div class="card shadow mb-4">
                <div class="card-body text-center">
                    <div class="mb-4">
                        <img class="img-profile rounded-circle img-thumbnail"
                             src="~/Images/Doctors/@(string.IsNullOrEmpty(Model.Img) ? "default-doctor.png" : Model.Img)"
                             style="width: 150px; height: 150px; object-fit: cover;">
                    </div>
                    <h4 class="font-weight-bold text-primary">Dr. @Model.FirstName @Model.LastName</h4>
                    <p class="text-muted mb-1">@Model.Specialty</p>
                    <p class="text-small text-gray-500"><i class="fas fa-id-badge mr-2"></i>ID: #@Model.Id</p>
                    <hr class="my-4">
                    <div class="text-left">
                        <div class="mb-2">
                            <span class="text-xs font-weight-bold text-uppercase text-gray-400">Phone Number</span>
                            <div class="h6 mb-0 font-weight-bold text-gray-800">@(Model.PhoneNumber ?? "N/A")</div>
                        </div>
                        <div class="mb-2">
                            <span class="text-xs font-weight-bold text-uppercase text-gray-400">Consultation Fee</span>
                            <div class="h6 mb-0 font-weight-bold text-success">@Model.ConsultationFee EGP</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-8 col-lg-7">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-calendar-alt mr-2"></i>Working Hours</h6>
                </div>
                <div class="card-body">
                    @if (Model.DoctorSchedules != null && Model.DoctorSchedules.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered">
                                <thead class="bg-light">
                                    <tr>
                                        <th>Day</th>
                                        <th>Start Time</th>
                                        <th>End Time</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var schedule in Model.DoctorSchedules.OrderBy(s => s.Day))
                                    {
                                        <tr>
                                            <td class="font-weight-bold">@schedule.Day</td>
                                            <td><span class="badge badge-light">@schedule.StartTime.ToString(@"hh\:mm")</span></td>
                                            <td><span class="badge badge-light">@schedule.EndTime.ToString(@"hh\:mm")</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-clock fa-3x text-gray-300 mb-3"></i>
                            <p class="text-gray-500">No schedules assigned yet.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>