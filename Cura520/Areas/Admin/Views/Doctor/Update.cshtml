@model Cura520.ViewModel.DoctorVM

@{
    ViewData["Title"] = "Update Doctor";
    Layout = "_AdminLayout";
}

<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Edit Doctor: @Model.Doctor.FirstName @Model.Doctor.LastName</h1>

    <form asp-action="Update" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Doctor.Id" />
        <input type="hidden" asp-for="Doctor.Img" />

        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">Doctor Profile</h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label>First Name</label>
                                    <input asp-for="Doctor.FirstName" class="form-control" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label>Last Name</label>
                                    <input asp-for="Doctor.LastName" class="form-control" />
                                </div>
                            </div>
                        </div>


                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label>Specialty</label>
                                    <input asp-for="Doctor.Specialty" class="form-control" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label>Phone Number</label>
                                    <input asp-for="Doctor.PhoneNumber" class="form-control" />
                                </div>
                            </div>
                        </div>
                        
                        <div class="form-group mb-3">
                            <label>Consultation Fees</label>
                            <input asp-for="Doctor.ConsultationFee" class="form-control" />
                        </div>
                        

                        <button type="submit" class="btn btn-success btn-icon-split mt-3">
                            <span class="icon text-white-50"><i class="fas fa-save"></i></span>
                            <span class="text">Update Doctor</span>
                        </button>
                    </div>
                </div>

                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">Manage Schedules</h6>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered">
                                <thead>
                                    <tr>
                                        <th>Day</th>
                                        <th>Shift</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in Model.DoctorSchedules)
                                    {
                                        <tr id="row-@s.Id">
                                            <td>@s.Day</td>
                                            <td>@s.StartTime.ToShortTimeString() - @s.EndTime.ToShortTimeString()</td>
                                            <td>
                                                <button type="button" onclick="deleteSchedule(@s.Id)" class="btn btn-danger btn-sm btn-circle">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.getElementById('imgInput').onchange = function (evt) {
            const [file] = this.files;
            if (file) {
                document.getElementById('imgPreview').src = URL.createObjectURL(file);
            }
        };
    </script>
}