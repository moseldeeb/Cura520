@using Cura520.ViewModel.Admin.Doctor
@model UpdateDoctorVM

@{
    ViewData["Title"] = "Update Doctor";
    Layout = "_AdminLayout";
}

<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Edit Doctor: @Model.FirstName @Model.LastName</h1>

    <form asp-action="Update" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="Img" />

        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">Doctor Profile</h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label>First Name</label>
                                    <input asp-for="FirstName" class="form-control" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label>Last Name</label>
                                    <input asp-for="LastName" class="form-control" />
                                </div>
                            </div>
                        </div>


                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label>Specialty</label>
                                    <input asp-for="Specialty" class="form-control" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label>Phone Number</label>
                                    <input asp-for="PhoneNumber" class="form-control" />
                                </div>
                            </div>
                        </div>
                        
                        <div class="form-group mb-3">
                            <label>Consultation Fees</label>
                            <input asp-for="ConsultationFee" class="form-control" />
                        </div>
                        
                        <div class="form-group mb-3">
                            <label>Profile Image</label>
                            <div class="mb-2">
                                <img id="imgPreview" src="~/Images/Doctors/@Model.Img" style="width:100px; height:100px; object-fit:cover;" class="img-thumbnail" />
                            </div>
                            <input asp-for="ImageFile" type="file" id="imgInput" class="form-control-file" />
                        </div>

                        <button type="submit" class="btn btn-success btn-icon-split mt-3">
                            <span class="icon text-white-50"><i class="fas fa-save"></i></span>
                            <span class="text">Update Doctor</span>
                        </button>
                    </div>
                </div>

                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">Manage Schedules</h6>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered">
                                <thead>
                                    <tr>
                                        <th>Day</th>
                                        <th>Shift</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in Model.DoctorSchedules)
                                    {
                                        <tr id="row-@s.Id">
                                            <td>@s.Day</td>
                                            <td>@s.StartTime.ToShortTimeString() - @s.EndTime.ToShortTimeString()</td>
                                            <td>
                                                <button type="button" onclick="deleteSchedule(@s.Id)" class="btn btn-danger btn-sm btn-circle">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.getElementById('imgInput').onchange = function (evt) {
            const [file] = this.files;
            if (file) {
                document.getElementById('imgPreview').src = URL.createObjectURL(file);
            }
        };

                function deleteSchedule(id) {
            if (confirm("Are you sure you want to delete this shift?")) {
                $.post('@Url.Action("DeleteSchedule", "Doctor")', { id: id }, function (res) {
                    if (res.success) {
                        $("#row-" + id).fadeOut(300, function() { $(this).remove(); });
                    } else {
                        alert("Error: " + res.message);
                    }
                });
            }
        }
    </script>
}