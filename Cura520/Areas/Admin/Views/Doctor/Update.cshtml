@using Cura520.ViewModel.Admin.Doctor
@model UpdateDoctorVM

@{
    ViewData["Title"] = "Update Doctor";
    Layout = "_AdminLayout";
}

<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Edit Doctor: @Model.FirstName @Model.LastName</h1>

    <form asp-action="Update" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ApplicationUserId" />
        <input type="hidden" asp-for="Img" />

        @if (Model.DoctorSchedules != null)
        {
            for (int i = 0; i < Model.DoctorSchedules.Count; i++)
            {
                <input type="hidden" name="DoctorSchedules[@i].Id" value="@Model.DoctorSchedules[i].Id" />
                <input type="hidden" name="DoctorSchedules[@i].DoctorId" value="@Model.DoctorSchedules[i].DoctorId" />
                <input type="hidden" name="DoctorSchedules[@i].Day" value="@((int)Model.DoctorSchedules[i].Day)" />
                <input type="hidden" name="DoctorSchedules[@i].StartTime" value="@Model.DoctorSchedules[i].StartTime.ToString("HH:mm")" />
                <input type="hidden" name="DoctorSchedules[@i].EndTime" value="@Model.DoctorSchedules[i].EndTime.ToString("HH:mm")" />
            }
        }

        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">Doctor Profile</h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="FirstName">First Name</label>
                                    <input asp-for="FirstName" class="form-control" />
                                    <span asp-validation-for="FirstName" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="LastName">Last Name</label>
                                    <input asp-for="LastName" class="form-control" />
                                    <span asp-validation-for="LastName" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="Specialty">Specialty</label>
                                    <input asp-for="Specialty" class="form-control" />
                                    <span asp-validation-for="Specialty" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="PhoneNumber">Phone Number</label>
                                    <input asp-for="PhoneNumber" class="form-control" />
                                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="ConsultationFee">Consultation Fees</label>
                            <input asp-for="ConsultationFee" class="form-control" type="number" step="0.01" />
                            <span asp-validation-for="ConsultationFee" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="ImageFile">Profile Image</label>
                            <div class="mb-2">
                                <img id="imgPreview" src="~/Images/Doctors/@(string.IsNullOrEmpty(Model.Img) ? "default-doctor.png" : Model.Img)" style="width:100px; height:100px; object-fit:cover;" class="img-thumbnail" />
                            </div>
                            <input asp-for="ImageFile" type="file" id="imgInput" class="form-control-file" />
                            <span asp-validation-for="ImageFile" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-success btn-icon-split mt-3">
                            <span class="icon text-white-50"><i class="fas fa-save"></i></span>
                            <span class="text">Update Doctor</span>
                        </button>
                    </div>
                </div>

                <div class="card shadow mb-4">
                    <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                        <h6 class="m-0 font-weight-bold text-primary">Manage Schedules</h6>
                        <button type="button" id="addSchedule" class="btn btn-success btn-sm">
                            <i class="fas fa-plus"></i> Add New Shift
                        </button>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive mb-4">
                            <table class="table table-bordered">
                                <thead>
                                    <tr>
                                        <th>Day</th>
                                        <th>Shift</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.DoctorSchedules != null)
                                    {
                                        foreach (var s in Model.DoctorSchedules)
                                        {
                                            <tr id="row-@s.Id">
                                                <td>@s.Day</td>
                                                <td>@s.StartTime.ToShortTimeString() - @s.EndTime.ToShortTimeString()</td>
                                                <td>
                                                    <button type="button" onclick="deleteSchedule(@s.Id)" class="btn btn-danger btn-sm btn-circle">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div id="new-schedule-container"></div>

                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('imgInput').onchange = function (evt) {
            const [file] = this.files;
            if (file) {
                document.getElementById('imgPreview').src = URL.createObjectURL(file);
            }
        };

        function deleteSchedule(id) {
            if (confirm("Are you sure you want to delete this shift?")) {
                $.post('@Url.Action("DeleteSchedule", "Doctor")', { id: id }, function (res) {
                    if (res.success) {
                        $("#row-" + id).fadeOut(300, function() { $(this).remove(); });
                        // Also remove the hidden input associated with this ID so it doesn't post back
                        $(`input.existing-schedule-id[value='${id}']`).closest('input').nextAll().addBack().slice(0, 4).remove();
                    } else {
                        alert("Error: " + res.message);
                    }
                });
            }
        }

        // Logic for adding NEW schedules to an existing doctor
        let index = @(Model.DoctorSchedules?.Count ?? 0);

        $("#addSchedule").click(function () {
            let row = `
                <div class="row mb-3 align-items-end new-schedule-row">
                    <div class="col-md-4">
                        <label>Day of Week</label>
                        <select name="DoctorSchedules[${index}].Day" class="form-control">
                            <option value="0">Sunday</option>
                            <option value="1">Monday</option>
                            <option value="2">Tuesday</option>
                            <option value="3">Wednesday</option>
                            <option value="4">Thursday</option>
                            <option value="5">Friday</option>
                            <option value="6">Saturday</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label>Start Time</label>
                        <input name="DoctorSchedules[${index}].StartTime" type="time" class="form-control" required />
                    </div>
                    <div class="col-md-3">
                        <label>End Time</label>
                        <input name="DoctorSchedules[${index}].EndTime" type="time" class="form-control" required />
                    </div>
                    <div class="col-md-2">
                        <button type="button" class="btn btn-warning btn-block remove-new-schedule">Undo</button>
                    </div>
                </div>`;
            $("#new-schedule-container").append(row);
            index++;
        });

        $(document).on("click", ".remove-new-schedule", function () {
            $(this).closest(".new-schedule-row").remove();
            reIndexNewSchedules();
        });

        function reIndexNewSchedules() {
            // We only re-index the newly added ones starting from the base count of existing schedules
            let baseCount = @(Model.DoctorSchedules?.Count ?? 0);
            $(".new-schedule-row").each(function (i, row) {
                let currIndex = baseCount + i;
                $(row).find("select").attr("name", `DoctorSchedules[${currIndex}].Day`);
                $(row).find("input[type='time']").first().attr("name", `DoctorSchedules[${currIndex}].StartTime`);
                $(row).find("input[type='time']").last().attr("name", `DoctorSchedules[${currIndex}].EndTime`);
            });
            index = baseCount + $(".new-schedule-row").length;
        }
    </script>
}