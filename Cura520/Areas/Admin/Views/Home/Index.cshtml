@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<main>
    <div class="container-fluid px-4">
        <h1 class="mt-4">Dashboard</h1>
        <ol class="breadcrumb mb-4">
            <li class="breadcrumb-item active">Dashboard</li>
        </ol>

        <!-- Dashboard Cards Row 1 -->
        <div class="row">
            <div class="col-xl-3 col-md-6">
                <div class="card bg-primary text-white mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title text-white-50">Total Patients</h6>
                                <h2 class="mb-0">1,250</h2>
                            </div>
                            <i class="fas fa-users fa-3x opacity-50"></i>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-top">
                        <a class="text-white small stretched-link" href="/Admin/Patients/Index">
                            View Details <i class="fas fa-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6">
                <div class="card bg-success text-white mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title text-white-50">Total Doctors</h6>
                                <h2 class="mb-0">45</h2>
                            </div>
                            <i class="fas fa-user-md fa-3x opacity-50"></i>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-top">
                        <a class="text-white small stretched-link" href="/Admin/Doctors/Index">
                            View Details <i class="fas fa-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6">
                <div class="card bg-warning text-white mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title text-white-50">Upcoming Appointments</h6>
                                <h2 class="mb-0">42</h2>
                            </div>
                            <i class="fas fa-calendar-check fa-3x opacity-50"></i>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-top">
                        <a class="text-white small stretched-link" href="/Admin/Appointments/Index">
                            View Details <i class="fas fa-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6">
                <div class="card bg-danger text-white mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title text-white-50">Revenue (Today)</h6>
                                <h2 class="mb-0">$4,200</h2>
                            </div>
                            <i class="fas fa-dollar-sign fa-3x opacity-50"></i>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-top">
                        <a class="text-white small stretched-link" href="/Admin/Invoices/Index">
                            View Details <i class="fas fa-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Dashboard Cards Row 2 -->
        <div class="row">
            <div class="col-xl-3 col-md-6">
                <div class="card bg-info text-white mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title text-white-50">Total Appointments</h6>
                                <h2 class="mb-0">3,892</h2>
                            </div>
                            <i class="fas fa-chart-bar fa-3x opacity-50"></i>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-top">
                        <a class="text-white small stretched-link" href="/Admin/Appointments/Index">
                            View Details <i class="fas fa-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6">
                <div class="card bg-secondary text-white mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title text-white-50">Pending Results</h6>
                                <h2 class="mb-0">18</h2>
                            </div>
                            <i class="fas fa-hourglass-end fa-3x opacity-50"></i>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-top">
                        <a class="text-white small stretched-link" href="/Admin/Results/Index">
                            View Details <i class="fas fa-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6">
                <div class="card bg-light text-dark mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title">Total Revenue (Month)</h6>
                                <h2 class="mb-0">$52,400</h2>
                            </div>
                            <i class="fas fa-money-bill-wave fa-3x opacity-50"></i>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-top">
                        <a class="text-dark small stretched-link" href="/Admin/Reports/Revenue">
                            View Details <i class="fas fa-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6">
                <div class="card text-white mb-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title text-white-50">System Users</h6>
                                <h2 class="mb-0">156</h2>
                            </div>
                            <i class="fas fa-user-tie fa-3x opacity-50"></i>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-top">
                        <a class="text-white small stretched-link" href="/Admin/Users/Index">
                            View Details <i class="fas fa-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Charts and Tables Section -->
        <div class="row">
            <!-- Chart Area -->
            <div class="col-xl-8">
                <div class="card mb-4">
                    <div class="card-header">
                        <strong class="card-title">Appointments Overview</strong>
                    </div>
                    <div class="card-body"><canvas id="myAreaChart" width="100%" height="40"></canvas></div>
                    <div class="card-footer small text-muted">Updated 3 minutes ago</div>
                </div>
            </div>

            <!-- Chart Bar -->
            <div class="col-xl-4">
                <div class="card mb-4">
                    <div class="card-header">
                        <strong class="card-title">Revenue Sources</strong>
                    </div>
                    <div class="card-body"><canvas id="myBarChart" width="100%" height="40"></canvas></div>
                    <div class="card-footer small text-muted">Updated 1 day ago</div>
                </div>
            </div>
        </div>

        <!-- Recent Activity Table -->
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong class="card-title">Recent Patient Activity</strong>
                <a href="/Admin/Appointments/Index" class="btn btn-sm btn-primary">View All</a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Patient Name</th>
                                <th>Doctor</th>
                                <th>Service</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Ahmed Ali</td>
                                <td>Dr. Sarah Johnson</td>
                                <td><span class="badge bg-light text-dark">General Check-up</span></td>
                                <td>2024-02-28</td>
                                <td><span class="badge bg-success">Confirmed</span></td>
                                <td>
                                    <button class="btn btn-sm btn-info" title="View"><i class="fas fa-eye"></i></button>
                                    <button class="btn btn-sm btn-warning" title="Edit"><i class="fas fa-edit"></i></button>
                                    <button class="btn btn-sm btn-danger" title="Delete"><i class="fas fa-trash"></i></button>
                                </td>
                            </tr>
                            <tr>
                                <td>Fatima Mohamed</td>
                                <td>Dr. Ahmed Hassan</td>
                                <td><span class="badge bg-light text-dark">Dental Cleaning</span></td>
                                <td>2024-02-27</td>
                                <td><span class="badge bg-warning">Pending</span></td>
                                <td>
                                    <button class="btn btn-sm btn-info" title="View"><i class="fas fa-eye"></i></button>
                                    <button class="btn btn-sm btn-warning" title="Edit"><i class="fas fa-edit"></i></button>
                                    <button class="btn btn-sm btn-danger" title="Delete"><i class="fas fa-trash"></i></button>
                                </td>
                            </tr>
                            <tr>
                                <td>Omar Ibrahim</td>
                                <td>Dr. Sara Williams</td>
                                <td><span class="badge bg-light text-dark">Eye Exam</span></td>
                                <td>2024-02-26</td>
                                <td><span class="badge bg-info">In Progress</span></td>
                                <td>
                                    <button class="btn btn-sm btn-info" title="View"><i class="fas fa-eye"></i></button>
                                    <button class="btn btn-sm btn-warning" title="Edit"><i class="fas fa-edit"></i></button>
                                    <button class="btn btn-sm btn-danger" title="Delete"><i class="fas fa-trash"></i></button>
                                </td>
                            </tr>
                            <tr>
                                <td>Noor Karim</td>
                                <td>Dr. Mohammed Ali</td>
                                <td><span class="badge bg-light text-dark">Vaccination</span></td>
                                <td>2024-02-25</td>
                                <td><span class="badge bg-success">Completed</span></td>
                                <td>
                                    <button class="btn btn-sm btn-info" title="View"><i class="fas fa-eye"></i></button>
                                    <button class="btn btn-sm btn-warning" title="Edit"><i class="fas fa-edit"></i></button>
                                    <button class="btn btn-sm btn-danger" title="Delete"><i class="fas fa-trash"></i></button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Management Shortcuts -->
        <div class="row">
            <div class="col-md-12">
                <div class="card mb-4">
                    <div class="card-header">
                        <strong class="card-title">Quick Management Actions</strong>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <a href="/Admin/Doctors/Create" class="btn btn-primary btn-block w-100 py-3">
                                    <i class="fas fa-plus-circle me-2"></i>
                                    Add New Doctor
                                </a>
                            </div>
                            <div class="col-md-3">
                                <a href="/Admin/Patients/Create" class="btn btn-success btn-block w-100 py-3">
                                    <i class="fas fa-user-plus me-2"></i>
                                    Register Patient
                                </a>
                            </div>
                            <div class="col-md-3">
                                <a href="/Admin/Appointments/Create" class="btn btn-warning btn-block w-100 py-3">
                                    <i class="fas fa-calendar-plus me-2"></i>
                                    Schedule Appointment
                                </a>
                            </div>
                            <div class="col-md-3">
                                <a href="/Admin/Reports/Index" class="btn btn-info btn-block w-100 py-3">
                                    <i class="fas fa-chart-line me-2"></i>
                                    View Reports
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        // Area Chart
        const ctx = document.getElementById("myAreaChart").getContext("2d");
        const myAreaChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"],
                datasets: [{
                    label: "Appointments",
                    lineTension: 0.3,
                    backgroundColor: "rgba(102, 126, 234, 0.1)",
                    borderColor: "rgba(102, 126, 234, 1)",
                    pointRadius: 5,
                    pointBackgroundColor: "rgba(102, 126, 234, 1)",
                    pointBorderColor: "rgba(255,255,255,0.8)",
                    pointHoverRadius: 7,
                    pointHoverBackgroundColor: "rgba(102, 126, 234, 1)",
                    pointHoverBorderColor: "rgba(255,255,255,1)",
                    pointHitRadius: 20,
                    pointBorderWidth: 2,
                    data: [10, 15, 12, 18, 22, 25, 28],
                }],
            },
            options: {
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: true
                    }
                },
                scales: {
                    xAxes: [{
                        time: {
                            unit: 'date'
                        },
                        gridLines: {
                            display: false,
                            drawBorder: false
                        }
                    }],
                    yAxes: [{
                        ticks: {
                            maxTicksLimit: 5
                        },
                        gridLines: {
                            color: "rgba(0, 0, 0, .125)"
                        }
                    }],
                }
            }
        });

        // Bar Chart
        const ctxBar = document.getElementById("myBarChart").getContext("2d");
        const myBarChart = new Chart(ctxBar, {
            type: 'bar',
            data: {
                labels: ["Consultations", "Treatments", "Tests", "Procedures"],
                datasets: [{
                    label: "Revenue ($)",
                    backgroundColor: ["#667eea", "#764ba2", "#f093fb", "#4facfe"],
                    borderColor: ["#667eea", "#764ba2", "#f093fb", "#4facfe"],
                    data: [12500, 15000, 8000, 16500],
                }],
            },
            options: {
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: true
                    }
                },
                scales: {
                    xAxes: [{
                        gridLines: {
                            display: false,
                            drawBorder: false
                        }
                    }],
                    yAxes: [{
                        ticks: {
                            maxTicksLimit: 5
                        },
                        gridLines: {
                            color: "rgba(0, 0, 0, .125)"
                        }
                    }],
                }
            }
        });
    </script>
}